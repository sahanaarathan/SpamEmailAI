# Copy this file to .env and fill in values

# UI mode — set to "true" to call FastAPI instead of direct prediction
USE_API=false

# FastAPI URL (used when USE_API=true)
API_URL=http://localhost:8000

# Docker Hub credentials (used in GitHub Actions CI/CD)
# DOCKERHUB_USERNAME=your_username
# DOCKERHUB_TOKEN=your_token
